# Either of these works. Token (Claude Pro/Max OAuth) is preferred.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=

# Optional: override the crewhaus-factory checkout the designer reads
# docs from. If unset, the designer uses $CWD when it looks like a
# crewhaus-factory checkout, otherwise clones to ~/.crewhaus/factory-cache.
CREWHAUS_FACTORY_PATH=
