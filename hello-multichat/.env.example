# hello-multichat — environment variables
#
# Pick ONE provider stanza below based on the `model:` in crewhaus.yaml,
# plus at least ONE channel's credentials.

# --- Model provider (default: Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...

# OR set crewhaus.yaml `agent.model:` to gpt-4o-2024-11-20 and:
# OPENAI_API_KEY=sk-...

# OR set crewhaus.yaml `agent.model:` to gemini-2.0-flash and:
# GOOGLE_API_KEY=...

# --- Slack (Bot Token + Signing Secret) ---
# Slack app config: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# --- Telegram ---
# Bot creation via @BotFather; secret token is a self-chosen webhook key.
TELEGRAM_BOT_TOKEN=...
TELEGRAM_SECRET_TOKEN=...

# --- Discord ---
# Discord Developer Portal: https://discord.com/developers/applications
DISCORD_APP_ID=...
DISCORD_BOT_TOKEN=...
DISCORD_PUBLIC_KEY=...

# --- Optional: MCP connectors (uncomment in crewhaus.yaml) ---
# GITHUB_TOKEN=ghp_...
