{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "types": ["bun"],
    "allowImportingTsExtensions": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    // SWAP-WHEN-PUBLISHED: until @crewhaus/* are on npm, we resolve them from
    // a sibling ../factory/ checkout. When the packages publish, delete this
    // "paths" block and add the @crewhaus/* imports each example's compiled
    // dist/ uses to a top-level package.json "dependencies". No other code
    // change is needed — every other reference to factory in this repo is
    // either a runtime file read (the spec source pulled by scripts) gated
    // behind FACTORY_PATH, or a shell-out to the factory CLI.
    "paths": {
      "@crewhaus/*": ["../factory/packages/*"]
    }
  },
  // No "include" by design: the tsconfig exists solely to provide the paths
  // block above (used at runtime by bun when running compiled bundles + smoke
  // scripts). Scripts under scripts/ originated in factory where they were
  // excluded from project references and never typechecked; they have ~10
  // pre-existing strictness warnings that are not actual bugs. Compiled
  // bundles in **/dist/ are generated by the factory CLI. Run `bun ...`
  // directly for either; there is no `bun run typecheck` script in
  // package.json because we don't author TypeScript here.
  "files": [],
  "exclude": ["node_modules", "**/node_modules"]
}
