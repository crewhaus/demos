{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "types": ["bun"],
    "allowImportingTsExtensions": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    // Post-v0.1.0: `@crewhaus/*` packages are on npm; default resolution goes
    // through node_modules. The paths block below is a contributor convenience
    // — if you also have a sibling ../factory/ or ../utilities/ checkout, bun
    // prefers it for live edits. Remove this paths block if you want strict
    // npm-only resolution (e.g. to reproduce what an external consumer sees).
    "paths": {
      "@crewhaus/*": ["../factory/packages/*", "../utilities/*"]
    }
  },
  // No "include" by design: the tsconfig exists solely to provide the paths
  // block above (used at runtime by bun when running compiled bundles + smoke
  // scripts). Scripts under scripts/ originated in factory where they were
  // excluded from project references and never typechecked; they have ~10
  // pre-existing strictness warnings that are not actual bugs. Compiled
  // bundles in **/dist/ are generated by the factory CLI. Run `bun ...`
  // directly for either; there is no `bun run typecheck` script in
  // package.json because we don't author TypeScript here.
  "files": [],
  "exclude": ["node_modules", "**/node_modules"]
}
