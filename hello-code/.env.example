# hello-code — environment variables
#
# Pick ONE provider stanza below based on the `model:` in crewhaus.yaml.

# --- Anthropic (default) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI ---
# Set crewhaus.yaml `agent.model:` to e.g. `gpt-4o-2024-11-20`
# OPENAI_API_KEY=sk-...

# --- Google Gemini ---
# Set crewhaus.yaml `agent.model:` to e.g. `gemini-2.0-flash`
# GOOGLE_API_KEY=...

# --- AWS Bedrock ---
# Set crewhaus.yaml `agent.model:` to e.g.
# `bedrock/anthropic.claude-sonnet-4-20250514-v1:0`
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# --- Optional: MCP servers ---
# Uncomment `mcp_servers.github` in crewhaus.yaml to enable.
# GITHUB_TOKEN=ghp_...
