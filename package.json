{
  "name": "crewhaus-demos",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "User-facing CrewHaus demos: hello-* example specs + 55 recipes + section-* example smokes. Depends on a sibling ../factory/ checkout for the compiler and CLI. Studio + IDE tooling moved to the sibling ../utilities/ checkout (crewhaus/utilities).",
