{
  "name": "crewhaus-demos",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "User-facing CrewHaus demos: hello-* example specs + 48 recipes + Studio/IDE tooling packages + section-* example smokes. Depends on a sibling ../factory/ checkout for the compiler and CLI.",
  "workspaces": ["packages/*", "examples/*"],
  "scripts": {
    "recipes:test": "bun scripts/test-recipes.ts",
    "recipes:smoke": "bun scripts/smoke-recipes.ts",
    "compile:hello": "bun ../factory/apps/cli/src/index.ts compile hello-cli/crewhaus.yaml -o hello-cli/dist",
    "run:hello": "bun hello-cli/dist/agent.ts",
    "compile:hello-workflow": "bun ../factory/apps/cli/src/index.ts compile hello-workflow/crewhaus.yaml -o hello-workflow/dist",
    "run:hello-workflow": "bun hello-workflow/dist/agent.ts",
    "compile:hello-channel": "bun ../factory/apps/cli/src/index.ts compile hello-channel/crewhaus.yaml -o hello-channel/dist",
    "run:hello-channel": "bun hello-channel/dist/daemon.ts",
    "compile:hello-graph": "bun ../factory/apps/cli/src/index.ts compile hello-graph/crewhaus.yaml -o hello-graph/dist",
    "run:hello-graph": "bun hello-graph/dist/agent.ts",
    "compile:hello-managed": "bun ../factory/apps/cli/src/index.ts compile hello-managed/crewhaus.yaml -o hello-managed/dist",
    "run:hello-managed": "bun hello-managed/dist/daemon.ts",
    "compile:hello-rag": "bun ../factory/apps/cli/src/index.ts compile hello-rag/crewhaus.yaml -o hello-rag/dist",
