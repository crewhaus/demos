{
  "name": "crewhaus-demos",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "User-facing CrewHaus demos: hello-* example specs + 55 recipes + section-* example smokes. Depends on a sibling ../factory/ checkout for the compiler and CLI. Studio + IDE tooling moved to the sibling ../utilities/ checkout (crewhaus/utilities).",
  "workspaces": ["examples/*"],
  "scripts": {
    "compile": "bun scripts/compile.ts",
    "run": "bun scripts/run.ts",
    "list": "bun scripts/list.ts",
    "compile:procode": "bun scripts/compile.ts hello-procode",
    "compile:prochat": "bun scripts/compile.ts hello-prochat",
    "compile:multichat": "bun scripts/compile.ts hello-multichat",
    "run:procode": "bun scripts/run.ts hello-procode",
    "run:prochat": "bun scripts/run.ts hello-prochat",
    "run:multichat": "bun scripts/run.ts hello-multichat",
    "recipes:test": "bun scripts/test-recipes.ts",
    "recipes:smoke": "bun scripts/smoke-recipes.ts",
    "smoke:section-12": "bun scripts/section-12-smoke.ts",
    "smoke:section-19": "bun scripts/section-19-smoke.ts",
    "smoke:section-20": "bun scripts/section-20-smoke.ts",
    "smoke:section-21": "bun scripts/section-21-smoke.ts",
    "smoke:section-22": "bun scripts/section-22-smoke.ts",
    "smoke:section-23-batch": "bun scripts/section-23-batch-smoke.ts",
    "smoke:section-23-res": "bun scripts/section-23-res-smoke.ts",
    "smoke:section-24": "bun scripts/section-24-smoke.ts",
    "smoke:section-25": "bun scripts/section-25-smoke.ts",
    "smoke:section-27": "bun examples/section-27-smoke/smoke.ts",
    "smoke:section-29": "bun examples/section-29-smoke/smoke.ts",
    "smoke:section-34": "bun examples/section-34-federation-smoke/smoke.ts",
    "smoke:hello-procode": "bun scripts/section-hello-procode-smoke.ts",
    "smoke:hello-prochat": "bun scripts/section-hello-prochat-smoke.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
