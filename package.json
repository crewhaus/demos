    "compile:hello-channel-whatsapp": "bun ../factory/apps/cli/src/index.ts compile hello-channel-whatsapp/crewhaus.yaml -o hello-channel-whatsapp/dist",
    "compile:hello-channel-imessage": "bun ../factory/apps/cli/src/index.ts compile hello-channel-imessage/crewhaus.yaml -o hello-channel-imessage/dist",
    "compile:hello-harness-designer": "bun ../factory/apps/cli/src/index.ts compile hello-harness-designer/crewhaus.yaml -o hello-harness-designer/dist",
    "run:hello-harness-designer": "bun hello-harness-designer/dist/agent.ts",
    "compile:hello-code": "bun ../factory/apps/cli/src/index.ts compile hello-code/crewhaus.yaml -o hello-code/dist",
