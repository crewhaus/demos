    "run:hello-research": "bun hello-research/dist/agent.ts",
    "compile:hello-batch": "bun ../factory/apps/cli/src/index.ts compile hello-batch/crewhaus.yaml -o hello-batch/dist",
    "run:hello-batch": "bun hello-batch/dist/agent.ts",
    "compile:hello-voice": "bun ../factory/apps/cli/src/index.ts compile hello-voice/crewhaus.yaml -o hello-voice/dist",
    "compile:hello-browser": "bun ../factory/apps/cli/src/index.ts compile hello-browser/crewhaus.yaml -o hello-browser/dist",
    "compile:hello-eval": "bun ../factory/apps/cli/src/index.ts compile hello-eval/crewhaus.yaml -o hello-eval/dist",
