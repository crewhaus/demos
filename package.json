    "compile:prochat": "bun scripts/compile.ts starters/showcases/prochat",
    "compile:multichat": "bun scripts/compile.ts starters/showcases/multichat",
    "run:procode": "bun scripts/run.ts starters/showcases/procode",
    "run:prochat": "bun scripts/run.ts starters/showcases/prochat",
    "run:multichat": "bun scripts/run.ts starters/showcases/multichat",
    "recipes:test": "bun scripts/test-recipes.ts",
    "recipes:smoke": "bun scripts/smoke-recipes.ts",
    "smoke:section-12": "bun smoke/section-12-smoke/smoke.ts",
    "smoke:section-19": "bun smoke/section-19-smoke/smoke.ts",
    "smoke:section-20": "bun smoke/section-20-smoke/smoke.ts",
    "smoke:section-21": "bun smoke/section-21-smoke/smoke.ts",
    "smoke:section-22": "bun smoke/section-22-smoke/smoke.ts",
