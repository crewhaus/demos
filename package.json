    "smoke:section-25": "bun smoke/section-25-smoke/smoke.ts",
    "smoke:section-27": "bun smoke/section-27-smoke/smoke.ts",
    "smoke:section-29": "bun smoke/section-29-smoke/smoke.ts",
    "smoke:section-34": "bun smoke/section-34-federation-smoke/smoke.ts",
    "smoke:hello-procode": "bun smoke/hello-procode-smoke/smoke.ts",
    "smoke:hello-prochat": "bun smoke/hello-prochat-smoke/smoke.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
